GEMINI_API_KEY=your-gemini-api-key-here
DATABASE_URL=postgresql+asyncpg://appuser:apppass@db:5432/networkdb
AUDIT_DATABASE_URL=postgresql+asyncpg://audituser:auditpass@db:5432/networkdb
SECRET_KEY=change-this-in-production-min-32-chars
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppass
POSTGRES_DB=networkdb
AUDIT_USER=audituser
AUDIT_PASSWORD=auditpass
ENVIRONMENT=development
LOG_LEVEL=INFO
GEMINI_MODEL=gemini-1.5-flash
RATE_LIMIT_PER_MINUTE=10
QUERY_TIMEOUT_SECONDS=5
